<Window
    x:Class="DriveVault.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DriveVault"
    Title="Drive Vault">

    <Grid x:Name="RootGrid">

        <NavigationView
            x:Name="NavView"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            IsSettingsVisible="False"
            SelectionChanged="NavView_SelectionChanged"
            OpenPaneLength="200">

            <NavigationView.Resources>

                <LinearGradientBrush x:Key="NavigationViewExpandedPaneBackground"
                                     StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0D1117" Offset="0.0"/>
                    <GradientStop Color="#0F2033" Offset="0.5"/>
                    <GradientStop Color="#1B3A5C" Offset="1.0"/>
                </LinearGradientBrush>

                <LinearGradientBrush x:Key="NavigationViewContentBackground"
                                     StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0D1117" Offset="0.0"/>
                    <GradientStop Color="#0F2033" Offset="0.5"/>
                    <GradientStop Color="#1B3A5C" Offset="1.0"/>
                </LinearGradientBrush>

                <SolidColorBrush x:Key="NavigationViewItemForeground"
                                 Color="White"/>
                <SolidColorBrush x:Key="NavigationViewItemForegroundSelected"
                                 Color="White"/>
                <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver"
                                 Color="White"/>
                <SolidColorBrush x:Key="NavigationViewItemForegroundPressed"
                                 Color="White"/>
                <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver"
                                 Color="White"/>
                <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed"
                                 Color="White"/>
                <SolidColorBrush x:Key="NavigationViewItemForegroundDisabled"
                                 Color="#88FFFFFF"/>

                <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground"
                                 Color="#4DA6FF"/>
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected"
                                 Color="#22FFFFFF"/>
                <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver"
                                 Color="#15FFFFFF"/>
                <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed"
                                 Color="#30FFFFFF"/>

                <SolidColorBrush x:Key="NavigationViewButtonForegroundPointerOver"
                                 Color="White"/>
                <SolidColorBrush x:Key="NavigationViewButtonForegroundPressed"
                                 Color="White"/>

                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush"
                                 Color="#0D1117"/>
                <SolidColorBrush x:Key="NavigationViewPaneBorderBrush"
                                 Color="#0D1117"/>
                <SolidColorBrush x:Key="NavigationViewItemSeparatorForeground"
                                 Color="Transparent"/>
                <Thickness x:Key="NavigationViewPaneBorderThickness">0</Thickness>

            </NavigationView.Resources>

            <!-- Logo + App name header -->
            <NavigationView.PaneHeader>
                <Grid Margin="16,8,16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0"
                           Source="ms-appx:///Images/DriveVault_HighRes.png"
                           Width="28" Height="28"
                           VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="Drive Vault"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </Grid>
            </NavigationView.PaneHeader>

            <!-- ✅ ADDED — Indexing progress banner in sidebar footer -->
            <NavigationView.PaneFooter>
                <Border x:Name="IndexingBanner"
                        Visibility="Collapsed"
                        Background="#22FFFFFF"
                        CornerRadius="8"
                        Margin="8,0,8,8"
                        Padding="12,8,12,8">
                    <StackPanel Spacing="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ProgressRing Grid.Column="0"
                                          IsActive="True"
                                          Width="16" Height="16"
                                          Foreground="White"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="IndexingDriveText"
                                       Text="Indexing..."
                                       Foreground="White"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2"
                                       x:Name="IndexingPercentText"
                                       Text="0%"
                                       Foreground="#AAFFFFFF"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <ProgressBar x:Name="IndexingProgressBar"
                                     Minimum="0" Maximum="100" Value="0"
                                     Height="3"
                                     Foreground="#4DA6FF"
                                     Background="#33FFFFFF"/>
                        <TextBlock x:Name="IndexingFolderText"
                                   Text=""
                                   Foreground="#88FFFFFF"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </NavigationView.PaneFooter>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Overview" Tag="overview">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Drives" Tag="drives">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEDA2;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Library" Tag="folders">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Clients" Tag="clients">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE716;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Activity" Tag="activity">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE823;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <AutoSuggestBox
                    Grid.Row="0"
                    x:Name="SearchBox"
                    PlaceholderText="Search drives, folders, clients..."
                    QueryIcon="Find"
                    CornerRadius="20"
                    Margin="16,8,150,8"
                    TextChanged="SearchBox_TextChanged"
                    SuggestionChosen="SearchBox_SuggestionChosen"/>
                <Frame Grid.Row="1" x:Name="ContentFrame"/>
            </Grid>

        </NavigationView>

        <Grid x:Name="SplashOverlay"
              Background="#0D1117"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Image Source="ms-appx:///Images/DriveVault_HighRes.png"
                   Width="320"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="SplashScale"
                                    ScaleX="0.9" ScaleY="0.9"/>
                </Image.RenderTransform>
            </Image>
        </Grid>

    </Grid>
</Window>
