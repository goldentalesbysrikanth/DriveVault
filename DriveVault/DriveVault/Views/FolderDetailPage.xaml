<Page
    x:Class="DriveVault.Views.FolderDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DriveVault.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Back Button + Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    Spacing="12" Margin="0,0,0,16">
            <Button x:Name="BackButton"
                    Content="← Back"
                    Click="BackButton_Click"/>
            <TextBlock x:Name="TitleText"
                       Text="Folder Detail"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Folder Info Card -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Size"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <!-- ✅ ADDED Foreground -->
                    <TextBlock x:Name="SizeText"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Drive"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <!-- ✅ ADDED Foreground -->
                    <TextBlock x:Name="DriveText"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="Date Added"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <!-- ✅ ADDED Foreground -->
                    <TextBlock x:Name="DateText"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Subfolders -->
        <StackPanel Grid.Row="2" Spacing="8">
            <TextBlock Text="Subfolders"
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <ListView x:Name="SubfoldersListView"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="📁"
                                           FontSize="18"
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>
                                <!-- ✅ ADDED Foreground -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <!-- ✅ ADDED Foreground -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Size}"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

    </Grid>
</Page>
