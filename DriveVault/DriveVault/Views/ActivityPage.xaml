<Page
    x:Class="DriveVault.Views.ActivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DriveVault.Views"
    xmlns:conv="using:DriveVault.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:ActivityDotColorConverter  x:Key="ActivityDotColorConverter"/>
        <conv:SubInfoVisibilityConverter x:Key="SubInfoVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Activity Log"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <ComboBox x:Name="DaysFilterCombo" Width="140"
                          SelectionChanged="DaysFilterCombo_SelectionChanged"/>
                <Button x:Name="ExportButton" Content="⬇ Export"
                        Click="ExportButton_Click"/>
                <Button x:Name="ResetButton" Content="🗑 Reset Log"
                        Click="ResetButton_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Total Events"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="TotalEventsText" Text="0"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Folders Added"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="FoldersAddedText" Text="0"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Folders Removed"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="FoldersRemovedText" Text="0"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Re-indexed"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="ReindexedText" Text="0"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <ListView Grid.Row="2" x:Name="ActivityListView" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ActivityItemViewModel">
                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1" Padding="8,12,8,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Ellipse Grid.Column="0" Width="10" Height="10"
                                     Fill="{x:Bind EventType, Converter={StaticResource ActivityDotColorConverter}}"
                                     VerticalAlignment="Top" Margin="0,4,14,0"/>

                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="{x:Bind Description}"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{x:Bind SubInfo}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{x:Bind SubInfo, Converter={StaticResource SubInfoVisibilityConverter}}"/>
                                <TextBlock Text="{x:Bind DriveName}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{x:Bind Timestamp}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>