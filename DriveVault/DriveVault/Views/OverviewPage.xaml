<Page
    x:Class="DriveVault.Views.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DriveVault.Views"
    xmlns:conv="using:DriveVault.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:StatusBadgeBgConverter    x:Key="StatusBadgeBgConverter"/>
        <conv:StatusBadgeFgConverter    x:Key="StatusBadgeFgConverter"/>
        <conv:ActivityDotColorConverter x:Key="ActivityDotColorConverter"/>
    </Page.Resources>

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24">

            <!-- Stats Cards -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Drives — visible, not clickable -->
                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="TOTAL DRIVES"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="TotalDrivesText" Text="0"
                                   FontSize="32" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ConnectedDrivesText" Text="0 connected"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Total Indexed — visible, not clickable -->
                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="TOTAL INDEXED"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="StorageUsedText" Text="0 GB"
                                   FontSize="32" FontWeight="SemiBold"/>
                        <TextBlock x:Name="StorageTotalText" Text="0 GB used"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Shoots Tracked — visible, not clickable -->
                <Border Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="SHOOTS TRACKED"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="TotalFoldersText" Text="0"
                                   FontSize="32" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ThisMonthText" Text="0 this month"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Alerts — clickable -->
                <Border Grid.Column="3"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16"
                        PointerPressed="AlertsCard_Click">
                    <StackPanel Spacing="4">
                        <TextBlock Text="ALERTS"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="AlertsCountText" Text="0"
                                   FontSize="32" FontWeight="SemiBold"/>
                        <TextBlock x:Name="AlertsDetailText"
                                   Text="All drives healthy"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <HyperlinkButton Content="View all →" Padding="0"
                                         Click="ViewAllDrives_Click"
                                         Foreground="#9B59B6"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Drive Status + Recent Activity -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Drive Status -->
                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEDA2;" FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="DRIVE STATUS"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <ListView x:Name="DrivesListView"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="DrivesListView_ItemClick">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment"
                                            Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:OverviewDriveViewModel">
                                    <StackPanel Spacing="6" Padding="0,8,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Label}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                            <Border Grid.Column="1"
                                                    Background="{x:Bind OnlineStatus, Converter={StaticResource StatusBadgeBgConverter}}"
                                                    CornerRadius="12" Padding="10,3">
                                                <TextBlock Text="{x:Bind OnlineStatus}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{x:Bind OnlineStatus, Converter={StaticResource StatusBadgeFgConverter}}"/>
                                            </Border>
                                        </Grid>
                                        <ProgressBar Value="{x:Bind UsedPercent}"
                                                     Maximum="100"
                                                     Foreground="#9B59B6"
                                                     Height="4" CornerRadius="2"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind UsedDisplay}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind FreeDisplay}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </Grid>
                                        <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                BorderThickness="0,0,0,1"
                                                Margin="0,4,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Right: Recent Activity -->
                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16"
                        MaxHeight="380">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE823;" FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="RECENT ACTIVITY"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <ScrollViewer MaxHeight="280" VerticalScrollMode="Auto">
                            <ListView x:Name="ActivityListView"
                                      SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment"
                                                Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:OverviewActivityViewModel">
                                        <Grid Padding="0,8,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="{x:Bind EventType, Converter={StaticResource ActivityDotColorConverter}}"
                                                    CornerRadius="12"
                                                    Width="28" Height="28"
                                                    Margin="0,0,10,0">
                                                <TextBlock Text="{x:Bind Icon}"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Description}"
                                                           Style="{ThemeResource BodyTextBlockStyle}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{x:Bind SubInfo}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind TimeAgo}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Top"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </ScrollViewer>
                        <HyperlinkButton x:Name="ViewAllEventsBtn"
                                         Padding="0"
                                         Click="ViewAllActivity_Click"
                                         Foreground="#9B59B6"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>