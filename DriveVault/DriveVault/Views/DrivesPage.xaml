<Page
    x:Class="DriveVault.Views.DrivesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DriveVault.Views"
    xmlns:conv="using:DriveVault.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:StatusBadgeBgConverter x:Key="StatusBadgeBgConverter"/>
        <conv:StatusBadgeFgConverter x:Key="StatusBadgeFgConverter"/>
        <conv:ProgressColorConverter x:Key="ProgressColorConverter"/>

        <MenuFlyout x:Key="DriveContextMenu">
            <MenuFlyoutItem x:Name="ReindexMenuItem"
                            Text="⟳ Re-index this drive"
                            Click="ReindexMenuItem_Click"/>
            <MenuFlyoutSeparator/>
            <MenuFlyoutItem x:Name="RemoveMenuItem"
                            Text="🗑 Remove drive"
                            Click="RemoveMenuItem_Click"/>
        </MenuFlyout>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ✅ Row 1: Filter buttons + Count -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                <Button x:Name="FilterAllBtn" Content="All"
                        Click="FilterBtn_Click" Tag="All"
                        Style="{ThemeResource AccentButtonStyle}"/>
                <Button x:Name="FilterOnlineBtn" Content="Online"
                        Click="FilterBtn_Click" Tag="Online"/>
                <Button x:Name="FilterOfflineBtn" Content="Offline"
                        Click="FilterBtn_Click" Tag="Offline"/>
                <Button x:Name="FilterNearlyFullBtn" Content="Nearly full"
                        Click="FilterBtn_Click" Tag="NearlyFull"/>
            </StackPanel>

            <TextBlock Grid.Column="1"
                       x:Name="DriveCountText"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"/>
        </Grid>

        <!-- ✅ Row 2: Sort + Actions — separate row, no overlap -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <ComboBox x:Name="SortCombo" Width="160"
                          SelectionChanged="SortCombo_SelectionChanged"/>
                <Button x:Name="ReindexAllButton" Content="⟳ Re-index All"
                        Click="ReindexAllButton_Click"/>
                <ToggleButton x:Name="GridViewToggle" Content="⊞" FontSize="16"
                              Checked="GridViewToggle_Checked"
                              Unchecked="GridViewToggle_Unchecked"
                              IsChecked="True"/>
            </StackPanel>
        </Grid>

        <!-- Row 3: Content -->
        <Grid Grid.Row="2">

            <GridView x:Name="DrivesGridView"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="DrivesGridView_ItemClick"
                      RightTapped="Drives_RightTapped"
                      Visibility="Visible">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="local:DriveItemViewModel">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="16" Width="260" Margin="0,0,12,12">
                            <StackPanel Spacing="10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#2D1B69"
                                            CornerRadius="8" Width="36" Height="36">
                                        <FontIcon Glyph="&#xEDA2;" FontSize="18"
                                                  Foreground="#9B59B6"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Label}"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind DriveType}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Background="{x:Bind OnlineStatus, Converter={StaticResource StatusBadgeBgConverter}}"
                                            CornerRadius="12" Padding="8,4">
                                        <TextBlock Text="{x:Bind OnlineStatus}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{x:Bind OnlineStatus, Converter={StaticResource StatusBadgeFgConverter}}"/>
                                    </Border>
                                </Grid>

                                <ProgressBar Value="{x:Bind UsedPercent}" Maximum="100"
                                             Foreground="{x:Bind UsedPercent, Converter={StaticResource ProgressColorConverter}}"
                                             Height="4" CornerRadius="2"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind UsedDisplay}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind FreeDisplay}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE722;" FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind ShootsCount}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind LastSeenText}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <ListView x:Name="DrivesListView"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="DrivesListView_ItemClick"
                      RightTapped="Drives_RightTapped"
                      Visibility="Collapsed">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:DriveItemViewModel">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#2D1B69"
                                        CornerRadius="8" Width="40" Height="40"
                                        Margin="0,0,16,0">
                                    <FontIcon Glyph="&#xEDA2;" FontSize="20"
                                              Foreground="#9B59B6"/>
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="4"
                                            VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind Label}"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <Border Background="{x:Bind OnlineStatus, Converter={StaticResource StatusBadgeBgConverter}}"
                                                CornerRadius="12" Padding="8,3">
                                            <TextBlock Text="{x:Bind OnlineStatus}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{x:Bind OnlineStatus, Converter={StaticResource StatusBadgeFgConverter}}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind SubInfo}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind LastSeenText}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <ProgressBar Value="{x:Bind UsedPercent}" Maximum="100"
                                                 Foreground="{x:Bind UsedPercent, Converter={StaticResource ProgressColorConverter}}"
                                                 Height="4"
                                                 HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                            HorizontalAlignment="Right" Spacing="4"
                                            Margin="12,0,0,0">
                                    <TextBlock Text="{x:Bind UsedDisplay}"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{x:Bind FreeDisplay}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{x:Bind ShootsCount}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>