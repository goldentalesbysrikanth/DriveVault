<Page
    x:Class="DriveVault.Views.ClientsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DriveVault.Views"
    xmlns:conv="using:DriveVault.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:AvatarColorConverter x:Key="AvatarColorConverter"/>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Clients"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       VerticalAlignment="Center"/>
            <AutoSuggestBox Grid.Column="1" x:Name="SearchBox"
                            PlaceholderText="Search clients..."
                            Width="220" QueryIcon="Find"
                            TextChanged="SearchBox_TextChanged"/>
        </Grid>

        <!-- Stats Cards -->
        <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Total Clients"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="TotalClientsText" Text="0"
                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Total Size"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="TotalSizeText" Text="0 GB"
                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Drives Used"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="DrivesUsedText" Text="0"
                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Workflows"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="WorkflowCountText" Text="0"
                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tab Buttons + Sort -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <Button x:Name="TabClientsBtn"
                        Content="Clients"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="TabClients_Click"/>
                <Button x:Name="TabWorkflowBtn"
                        Content="Workflow"
                        Click="TabWorkflow_Click"/>

                <!-- Workflow Filters -->
                <StackPanel x:Name="WfFiltersPanel"
                            Orientation="Horizontal"
                            Spacing="6"
                            Margin="16,0,0,0"
                            Visibility="Collapsed">
                    <Button x:Name="WfFilterAllBtn"
                            Content="All" Tag="All"
                            Style="{ThemeResource AccentButtonStyle}"
                            Click="WfFilter_Click"/>
                    <Button x:Name="WfFilterAttachedBtn"
                            Content="Attached" Tag="Attached"
                            Click="WfFilter_Click"/>
                    <Button x:Name="WfFilterPendingBtn"
                            Content="Pending" Tag="Pending"
                            Click="WfFilter_Click"/>
                    <Button x:Name="WfFilterInProgressBtn"
                            Content="In Progress" Tag="InProgress"
                            Click="WfFilter_Click"/>
                    <Button x:Name="WfFilterDoneBtn"
                            Content="Completed" Tag="Completed"
                            Click="WfFilter_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- ✅ Sort by Drive -->
            <StackPanel Grid.Column="1"
                        x:Name="SortPanel"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <TextBlock Text="Sort by:"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <ComboBox x:Name="SortComboBox"
                          Width="160"
                          SelectionChanged="SortComboBox_SelectionChanged"/>
            </StackPanel>
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="3">

            <!-- Clients ListView -->
            <ListView x:Name="ClientsListView"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="ClientsListView_ItemClick">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ClientViewModel">
                        <Border Background="{x:Bind HighlightBackground, Mode=OneTime}"
                                CornerRadius="8" Margin="0,0,0,4" Padding="2">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8">
                                <Grid Padding="16,12,16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar -->
                                    <Border Grid.Column="0"
                                            Background="{x:Bind FolderName, Converter={StaticResource AvatarColorConverter}}"
                                            CornerRadius="22" Width="44" Height="44"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="{x:Bind Initials}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Name + SubInfo -->
                                    <StackPanel Grid.Column="1" Spacing="3"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind FolderName}"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind SubInfo}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- Workflow badge -->
                                    <Border Grid.Column="2"
                                            CornerRadius="12" Padding="10,4"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush Color="#1A7C3AED"/>
                                        </Border.Background>
                                        <TextBlock Text="{x:Bind WorkflowBadgeText}"
                                                   FontSize="11"
                                                   Foreground="#9B59B6"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Drive name -->
                                    <StackPanel Grid.Column="3"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                VerticalAlignment="Center"
                                                Margin="0,0,12,0">
                                        <FontIcon Glyph="&#xEDA2;" FontSize="14"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind DriveName}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <FontIcon Grid.Column="4"
                                              Glyph="&#xE76C;" FontSize="12"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Workflow Panel -->
            <Grid x:Name="WorkflowPanel" Visibility="Collapsed">
                <ListView x:Name="WorkflowListView"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="WorkflowListView_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:WorkflowViewModel">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    Margin="0,0,0,4" Padding="16,12,16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Avatar -->
                                    <Border Grid.Column="0" Grid.RowSpan="3"
                                            Background="{x:Bind AvatarColor}"
                                            CornerRadius="22" Width="44" Height="44"
                                            Margin="0,0,16,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Initials}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Client name + days -->
                                    <StackPanel Grid.Column="1" Grid.Row="0" Spacing="2">
                                        <TextBlock Text="{x:Bind ClientName}"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind DaysInfo}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- Status items -->
                                    <StackPanel Grid.Column="1" Grid.Row="1"
                                                Orientation="Horizontal"
                                                Spacing="16" Margin="0,6,0,0">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Photos"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind PhotosLabel}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Cinematic"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind CinLabel}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Traditional"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind TradLabel}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Album"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind AlbumLabel}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Progress bar -->
                                    <ProgressBar Grid.Column="1" Grid.Row="2"
                                                 Value="{x:Bind ProgressPercent}"
                                                 Maximum="100"
                                                 Foreground="#9B59B6"
                                                 Height="4" CornerRadius="2"
                                                 Margin="0,8,0,0"/>

                                    <!-- Status badge -->
                                    <Border Grid.Column="2" Grid.Row="0"
                                            CornerRadius="12" Padding="10,4"
                                            VerticalAlignment="Top">
                                        <Border.Background>
                                            <SolidColorBrush Color="#1A7C3AED"/>
                                        </Border.Background>
                                        <TextBlock Text="{x:Bind StatusBadgeText}"
                                                   FontSize="11" Foreground="#9B59B6"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>